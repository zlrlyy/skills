# Email Marketing Skill - 环境变量配置示例
# 复制此文件为 .env 并填写真实值

# ============ 必需配置 ============
# 邮箱账号（用于发送和接收）
EMAIL_SMTP_USER=your-email@example.com
EMAIL_SMTP_PASS=your-password

# 测试邮箱（用于测试发送）
EMAIL_TEST_TARGET=test@example.com


# ============ 可选配置 ============
# SMTP 服务器配置（默认为网易企业邮箱）
EMAIL_SMTP_HOST=smtp.corp.netease.com
EMAIL_SMTP_PORT=465

# IMAP 服务器配置（用于收取回信）
EMAIL_IMAP_HOST=imap.corp.netease.com
EMAIL_IMAP_PORT=993


# ============ 文件路径配置 ============
# Excel 名单文件路径
EMAIL_EXCEL_PATH=~/Desktop/邮箱.xlsx

# HTML 邮件内容文件路径
EMAIL_HTML_PATH=~/Desktop/邮件内容.html

# 邮件标题文件路径
EMAIL_TITLE_PATH=~/Desktop/邮件标题.txt

# FAQ 知识库文件路径（自动回信功能需要）
EMAIL_FAQ_PATH=~/Desktop/faq.txt


# ============ 常见邮箱服务商配置参考 ============

# Gmail:
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=465
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_IMAP_PORT=993

# QQ邮箱:
# EMAIL_SMTP_HOST=smtp.qq.com
# EMAIL_SMTP_PORT=465
# EMAIL_IMAP_HOST=imap.qq.com
# EMAIL_IMAP_PORT=993

# 163邮箱:
# EMAIL_SMTP_HOST=smtp.163.com
# EMAIL_SMTP_PORT=465
# EMAIL_IMAP_HOST=imap.163.com
# EMAIL_IMAP_PORT=993

# Outlook/Hotmail:
# EMAIL_SMTP_HOST=smtp-mail.outlook.com
# EMAIL_SMTP_PORT=587
# EMAIL_IMAP_HOST=outlook.office365.com
# EMAIL_IMAP_PORT=993
